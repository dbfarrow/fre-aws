# Terraform
.terraform/
# Note: .terraform.lock.hcl should be committed — it pins provider versions.
*.tfstate
*.tfstate.backup
*.tfstate.*.backup
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
terraform/.tfplan*
terraform/imports_repair.tf
terraform/lambda/scheduled_stop.zip
terraform/lambda/app_api.zip

# Terraform variable files that may contain secrets
*.auto.tfvars
*.auto.tfvars.json
# Keep terraform.tfvars.example but ignore actual tfvars
terraform.tfvars
terraform.tfvars.json

# AWS credentials and config (should be mounted, never committed)
.aws/
*.pem
*.key
*_rsa
*_ed25519

# Environment files
.env
.env.*
!.env.example

# Local config with real credentials — never commit these
# All *.env files under config/ are gitignored; only *.example files are tracked.
config/*.env
config/users.tfvars
config/backend.env
# Generated by bootstrap.sh — contains real account ID and SSO URL
config/aws-config-admin.example

# Onboarding bundles contain SSH private keys — never commit these
config/onboarding/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Docker
.docker/

# Claude Code local settings
.claude/

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Test output
*.log
test-results/
