# AWS credentials for IAM user access keys — Option B (free tier)
#
# HOW TO USE:
#   1. Copy this file to ~/.aws/credentials  (no file extension)
#   2. Replace the placeholder values with your actual access key and secret
#      from the CSV you downloaded when creating the IAM user access key
#   3. Run: ./run.sh verify
#
# SECURITY REMINDER:
#   - Never commit this file or share it
#   - Enable MFA on your IAM user in the AWS Console
#   - Rotate this key periodically (IAM → Users → Security credentials)

[claude-code]
aws_access_key_id = YOUR_ACCESS_KEY_ID
aws_secret_access_key = YOUR_SECRET_ACCESS_KEY
