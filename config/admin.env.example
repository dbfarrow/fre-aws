# fre-aws configuration — EXAMPLE FILE
#
# Copy this file to config/admin.env and fill in your values:
#   cp config/admin.env.example config/admin.env
#
# config/admin.env is gitignored and never committed — safe to store
# tokens and personal settings there without risk of accidental exposure.
# This example file is committed and tracks new settings as the project evolves.

# ---- Repository --------------------------------------------------------------

# Git clone URL for the project repo. Included in admin onboarding emails so
# new admins know where to clone from. Leave empty to omit from the email.
# REPO_URL=https://github.com/your-org/your-repo.git

# ---- Required ----------------------------------------------------------------

# Unique project name: lowercase letters, numbers, hyphens. 3-25 characters.
# Used as a prefix for all AWS resource names and the S3 state bucket.
PROJECT_NAME=fre-aws

# AWS region to deploy into.
AWS_REGION=us-east-1

# AWS CLI profile name (from ~/.aws/config).
# Use the profile name you set during `aws configure sso` or `aws configure`.
AWS_PROFILE=claude-code

# ---- Instance ----------------------------------------------------------------

# EC2 instance type. t3.micro is Free Tier eligible for the first 12 months.
INSTANCE_TYPE=t3.micro

# Use spot instances to reduce cost (true/false). Default: false.
#
# WARNING — BREAKING CHANGE: switching this value on an existing environment
# destroys and recreates ALL instances. Terraform changes the underlying
# resource type (aws_spot_instance_request vs aws_instance), which forces
# replacement regardless of user_data_replace_on_change. All instance storage
# is wiped. Only change this setting before initial provisioning, or when you
# are prepared to reprovision every user's machine from scratch.
#
# Spot instances save 60-90% vs on-demand but can be interrupted with 2-minute
# notice. EBS data is preserved on interruption (behavior=stop), but the
# instance must be manually restarted. Use on-demand (false) for environments
# where uptime predictability matters more than cost.
USE_SPOT=false

# ---- Network -----------------------------------------------------------------

# Network topology. See README.md for full cost/security comparison.
#   public           - Free Tier friendly, single SG protection layer
#   private_nat      - Private subnet + NAT Gateway (~$33/month, defense in depth)
#   private_endpoints - Private subnet + VPC endpoints (~$22/month, no internet)
NETWORK_MODE=public

# ---- Storage -----------------------------------------------------------------

# Root EBS volume size in GB. Free Tier includes 30 GB/month.
# Must be >= the AMI root snapshot size (Amazon Linux 2023 requires >= 30 GB).
EBS_VOLUME_SIZE_GB=30

# ---- IAM Identity Center (SSO) -----------------------------------------------

# Region where IAM Identity Center is configured. This may differ from
# AWS_REGION — Identity Center is homed to a single region per organization.
# Find it: AWS Console → IAM Identity Center → Settings → Region.
#
# Required for IDENTITY_MODE=managed — bootstrap creates permission sets in Identity Center.
# Not needed for IDENTITY_MODE=external — users have org-managed IC roles and bootstrap
# skips all Identity Center operations entirely.
# Leave empty if using IAM user access keys (Option B) — bootstrap will skip
# permission set creation entirely.
SSO_REGION=

# AWS CLI profile for Identity Center management operations (managed mode, cross-account only).
# Set when IC lives in a different AWS account from your deploy target.
# Leave empty when IC and deploy are in the same account (default).
# SSO_PROFILE=

# SSO portal start URL. Required for auto-generating developer aws configs in add-user.
# Find it: IAM Identity Center → Dashboard → AWS access portal URL
# Example: https://d-abc1234567.awsapps.com/start
SSO_START_URL=

# Identity management mode.
#   managed   - fre-aws creates and manages IAM Identity Center users and permission
#               sets. Default when fre-aws is managing SSO.
#   external  - IAM Identity Center is federated with an external IdP (Okta, Azure AD,
#               etc.). fre-aws skips ALL Identity Center operations: no permission sets
#               are created, and add-user/remove-user won't create or delete IC users.
#               Users authenticate via their existing org IC roles — no special fre-aws
#               profiles needed. SSO_REGION is not required.
#               Users must supply their own SSH keys; no onboarding email is sent.
IDENTITY_MODE=managed

# ---- Email (SES) -------------------------------------------------------------

# Verified sender address in AWS SES.
# When set, bootstrap.sh triggers SES email verification (one-time click required),
# and add-user automatically emails credentials to new developers.
# Leave empty to skip email — credentials are saved to config/onboarding/<username>/ instead.
SENDER_EMAIL=

# Optional: URL of a banner image shown at the top of onboarding emails (HTTPS).
# Omit for a clean text-only header — the email looks good either way.
# LOGO_URL=

# ---- Web Preview -------------------------------------------------------------

# Local port for the EC2 web preview server (http://localhost:<port>).
# Forwarded automatically via SSH tunnel during connect. Change this if 8080
# is already in use on your machine.
WEB_PREVIEW_PORT=8080

# ---- SSH (Admin) -------------------------------------------------------------

# SSH private key for EC2 instance access (admin connect and refresh only).
# Defaults to ~/.ssh/id_ed25519, then ~/.ssh/id_rsa if neither is found.
# Must be a file inside ~/.ssh/ (that directory is mounted into the container).
# SSH_KEY_FILE=~/.ssh/id_ed25519

# ---- Optional ----------------------------------------------------------------

# Your email address, added as an Owner tag on AWS resources.
OWNER_EMAIL=

# ---- Billing -----------------------------------------------------------------

# Email address for billing alerts. Leave empty to disable all billing resources.
# When set, creates:
#   - Monthly spend budget alert (actual + forecasted) at BUDGET_ALERT_THRESHOLD_PERCENT
#   - Zero-spend sentinel: fires the moment any charges appear
#   - Cost anomaly detection: daily digest of unexpected spending spikes
BILLING_ALERT_EMAIL=

# Monthly budget ceiling in USD.
MONTHLY_BUDGET_USD=10

# Percentage of monthly budget at which alerts fire (actual and forecasted).
BUDGET_ALERT_THRESHOLD_PERCENT=80

# Minimum anomaly size in USD to trigger a cost anomaly alert.
ANOMALY_THRESHOLD_USD=5

# Set to false if your account already has a Cost Explorer anomaly monitor
# or you hit AWS's per-account limit on dimensional monitor creation.
ENABLE_ANOMALY_DETECTION=true

# Auto-stop all running instances at midnight Pacific time (true/false).
# Prevents forgotten instances from running overnight and incurring charges.
ENABLE_SCHEDULED_STOP=true

# ---- Browser app -------------------------------------------------------------

# Deploy the browser-based user app (Lambda + S3 + CloudFront).
# Set to true to give users a zero-install path to their Claude Code instance.
# After setting to true, run ./admin.sh up, then set WEB_APP_URL below.
ENABLE_WEB_APP=false

# Browser app URL. Set this after deploying with ENABLE_WEB_APP=true:
#   terraform -chdir=terraform output -raw app_url
# Used by: ./admin.sh publish-app-link <user>
# WEB_APP_URL=

# Optional: custom domain for the browser app (e.g. app.myproject.com).
# Leave empty to use the auto-generated CloudFront domain.
# APP_DOMAIN=

# Route 53 hosted zone ID. Required only if APP_DOMAIN is set.
# Find it: AWS Console → Route 53 → Hosted Zones
# ROUTE53_ZONE_ID=
