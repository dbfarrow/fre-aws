# config/users.tfvars — Rendered per-user provisioning configuration.
#
# NOTE: This file is auto-generated at runtime from S3.
# Do NOT edit it manually — use the CLI instead:
#
#   ./admin.sh add-user              — interactive wizard to add a user
#   ./admin.sh remove-user <name>    — remove a user (destroys instance on next up)
#
# The source of truth is: s3://<project>-tfstate/<project>/users.json
# It is written by add-user.sh / remove-user.sh and downloaded by up.sh / down.sh.
#
# This example file is tracked in git to show the rendered HCL format.
# config/users.tfvars itself is gitignored (it contains SSH public keys).
#
# Each key in the map (e.g. "alice") becomes:
#   - The Username tag on the EC2 instance
#   - The argument to admin.sh commands: ./admin.sh start alice

users = {
  alice = {
    ssh_public_key = "ssh-ed25519 AAAA... alice@company.com"
    git_user_name  = "Alice Smith"
    git_user_email = "alice@company.com"
  }

  # Keys with dots or other special characters must be quoted:
  # "farrow.daveb" = {
  #   ssh_public_key = "ssh-ed25519 AAAA... farrow.daveb@company.com"
  #   git_user_name  = "Dave Farrow"
  #   git_user_email = "farrow.daveb@company.com"
  # }
}
