# add-user input file — pass to: ./admin.sh add-user config/this-file.env
#
# Required fields:
NEW_USERNAME=alice
FULL_NAME="Alice Smith"
USER_EMAIL=alice@example.com

# Optional fields (defaults shown):
ROLE=user                          # user (default) or admin
# SSH_PUBLIC_KEY="ssh-ed25519 AAAA..."  # auto-generated if omitted
# GIT_USER_NAME="Alice Smith"      # defaults to FULL_NAME
# GIT_USER_EMAIL=alice@example.com # defaults to USER_EMAIL
