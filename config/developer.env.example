# fre-aws developer configuration — EXAMPLE FILE
#
# Copy to config/developer.env and fill in your values:
#   cp config/developer.env.example config/developer.env
#
# config/developer.env is gitignored and never committed.
# This example file is tracked so new settings appear here as the project evolves.

# ---- Required ----------------------------------------------------------------

# Your username — must match the key your admin used when adding you to users.tfvars.
# Ask your admin: what username did you use for me?
MY_USERNAME=yourname

# AWS CLI profile name from ~/.aws/config (your SSO profile).
# This should match the profile you set up when following README-developer.md.
AWS_PROFILE=claude-code

# AWS region — must match your admin's deployment region.
# Ask your admin: what region is the environment deployed in?
AWS_REGION=us-east-1

# Project name — must match your admin's PROJECT_NAME.
# Ask your admin: what is the project name?
PROJECT_NAME=fre-aws

# ---- Git identity ------------------------------------------------------------

# Your name and email for git commits. Written to git config at provisioning
# time and refreshed at every connect.
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=you@company.com
